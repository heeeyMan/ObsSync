{
	"name": "git-vault-sync",
	"version": "0.1.13",
	"description": "Git Vault Sync — one-click Git sync for Obsidian with conflict resolution (EN/RU).",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node scripts/regression.mjs"
	},
	"keywords": [
		"obsidian",
		"git",
		"sync"
	],
	"author": "alexandervasin",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"buffer": "^6.0.3",
		"esbuild": "^0.24.0",
		"obsidian": "^1.7.2",
		"process": "^0.11.10",
		"typescript": "^5.6.0"
	},
	"dependencies": {
		"isomorphic-git": "^1.27.1"
	}
}
