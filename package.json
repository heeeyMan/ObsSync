{
	"name": "obssync",
	"version": "0.1.0",
	"description": "One-click Git sync for Obsidian with conflict resolution.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": ["obsidian", "git", "sync"],
	"author": "alexandervasin",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.24.0",
		"obsidian": "^1.7.2",
		"typescript": "^5.6.0"
	},
	"dependencies": {
		"isomorphic-git": "^1.27.1"
	}
}
